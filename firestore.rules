rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles - users can read their own, but restricted writes
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can update ONLY safe fields (not tier, stripe*, or upgradedAt)
      // Those are set server-side via Firebase Admin (webhook handler).
      // Using `update` (not `write`) so this rule doesn't conflict with `create` below
      // and doesn't accidentally cover `delete` (which would error on resource.data).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['tier', 'stripeCustomerId', 'stripeSubscriptionId', 'upgradedAt']);

      // Allow creation with default profile (tier must be 'free')
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.tier == 'free';

      // Session history subcollection — users can read/write their own sessions
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Active threads - users can only read/write their own
    match /threads/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════════════
    // THERAPY EDITION: Phase 1 & 2 Collections
    // ═══════════════════════════════════════════════════════════════

    // Therapy profiles - extends user profile with therapy-specific data
    match /therapyProfiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Homework assignments - patients can read/write their own
    match /homeworkAssignments/{assignmentId} {
      allow read: if request.auth != null 
                  && (resource.data.patientId == request.auth.uid 
                      || resource.data.therapistId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.patientId == request.auth.uid 
                                || resource.data.therapistId == request.auth.uid);
    }

    // Week summaries - patient-owned, therapist can read with consent
    match /weekSummaries/{userId}/weeks/{weekId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Coping anchors - therapist-set strategies for patients
    match /copingAnchors/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Safe messaging mode flags
    match /safeModeFlags/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only server can write safe mode flags (via Admin SDK)
      allow write: if false;
    }

    // Session debriefs - post-therapy reflections
    match /sessionDebriefs/{userId}/debriefs/{debriefId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Pre-session primers
    match /preSessionPrimers/{userId}/primers/{primerId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Question DNA profiles (honesty by question type)
    match /questionDna/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Server-side updates only
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // THERAPIST COLLECTIONS (Phase 2)
    // ═══════════════════════════════════════════════════════════════

    // Therapist profiles
    match /therapists/{therapistId} {
      allow read: if request.auth != null && request.auth.uid == therapistId;
      allow write: if request.auth != null && request.auth.uid == therapistId
                   && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['verified', 'licenseVerified']);
    }

    // Practice records
    match /practices/{practiceId} {
      allow read: if request.auth != null 
                  && resource.data.therapistIds.hasAny([request.auth.uid]);
      // Create: check the incoming data (request.resource) since no document exists yet
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid;
      // Update/delete: check the existing document (resource) to prevent ownership hijack
      allow update, delete: if request.auth != null 
                            && resource.data.ownerId == request.auth.uid;
    }

    // Consent records - critical for GDPR compliance
    match /therapistConsent/{consentId} {
      // Patient can read/write their own consent
      allow read: if request.auth != null 
                  && (resource.data.patientId == request.auth.uid 
                      || resource.data.therapistId == request.auth.uid);
      // Only patient can grant/revoke consent
      allow write: if request.auth != null 
                   && request.resource.data.patientId == request.auth.uid;
    }

    // Consent audit log - append-only for compliance
    match /consentAuditLog/{logId} {
      allow read: if request.auth != null 
                  && (resource.data.patientId == request.auth.uid 
                      || resource.data.therapistId == request.auth.uid);
      // Server-side only writes
      allow write: if false;
    }

    // Pattern alerts for therapists
    match /patternAlerts/{alertId} {
      allow read: if request.auth != null 
                  && resource.data.therapistId == request.auth.uid;
      // Server-side only
      allow write: if false;
    }

    // Progress milestones
    match /progressMilestones/{userId}/milestones/{milestoneId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Server-side only
      allow write: if false;
    }

    // Discharge archives
    match /dischargeArchives/{archiveId} {
      allow read: if request.auth != null 
                  && resource.data.patientId == request.auth.uid;
      // Server-side only creation
      allow write: if false;
    }

    // Mood tracking data
    match /moodTracking/{userId}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════════════
    // V2: NHS/UK IAPT COLLECTIONS
    // ═══════════════════════════════════════════════════════════════

    // Outcome measures (PHQ-9, GAD-7, WSAS)
    match /outcomeMeasures/{measureId} {
      allow read: if request.auth != null 
                  && resource.data.userId == request.auth.uid;
      // Server-side only writes
      allow write: if false;
    }

    // Treatment episodes (stepped care)
    match /treatmentEpisodes/{episodeId} {
      allow read: if request.auth != null 
                  && (resource.data.patientId == request.auth.uid 
                      || resource.data.therapistId == request.auth.uid);
      // Server-side only writes
      allow write: if false;
    }

    // Session notes (clinical documentation)
    match /sessionNotes/{noteId} {
      allow read: if request.auth != null 
                  && resource.data.therapistId == request.auth.uid;
      // Server-side only writes
      allow write: if false;
    }

    // Session notes audit log
    match /sessionNotesAudit/{logId} {
      allow read: if request.auth != null 
                  && resource.data.therapistId == request.auth.uid;
      allow write: if false;
    }

    // Safeguarding concerns
    match /safeguardingConcerns/{concernId} {
      allow read: if request.auth != null 
                  && resource.data.therapistId == request.auth.uid;
      // Server-side only writes
      allow write: if false;
    }

    // Safeguarding audit log
    match /safeguardingAudit/{logId} {
      allow read: if request.auth != null 
                  && resource.data.therapistId == request.auth.uid;
      allow write: if false;
    }

    // Self-referrals (public submission, therapist read)
    match /selfReferrals/{referralId} {
      // Only the assigned therapist or the referring patient can read
      allow read: if request.auth != null 
                  && (resource.data.assignedTherapistId == request.auth.uid
                      || resource.data.userId == request.auth.uid);
      // Creation and updates handled server-side via Admin SDK
      allow write: if false;
    }

    // Referral audit log
    match /referralAudit/{logId} {
      // Only the therapist involved can read audit entries
      allow read: if request.auth != null 
                  && resource.data.therapistId == request.auth.uid;
      allow write: if false;
    }

    // Waiting list profiles — managed by Admin SDK, but allow owner reads
    match /waitingListProfiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Server-side only via Admin SDK
    }

    // Waiting list check-ins — managed by Admin SDK, but allow owner reads
    match /waitingListCheckIns/{checkInId} {
      allow read: if request.auth != null 
                  && resource.data.userId == request.auth.uid;
      allow write: if false; // Server-side only via Admin SDK
    }

    // Daily mood check-ins
    match /dailyMoodChecks/{userId}/checks/{dateId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Relapse prevention plans
    match /relapsePlans/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Data retention records
    match /dataRetention/{recordId} {
      // Server-side only
      allow read, write: if false;
    }

    // Deletion requests (GDPR)
    match /deletionRequests/{requestId} {
      allow read: if request.auth != null 
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
