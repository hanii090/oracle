# ============================================
# Oracle — Environment Variables
# ============================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to source control.

# ---- Firebase (Public — safe for client-side) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (Server-side only) ----
# Paste the full JSON content of your service account key (single line)
FIREBASE_SERVICE_ACCOUNT_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PHILOSOPHER=
STRIPE_PRICE_ID_PRO=

# ---- AI Keys (Server-side only — NOT prefixed with NEXT_PUBLIC_) ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=

# ---- App ----
APP_URL=http://localhost:3000
